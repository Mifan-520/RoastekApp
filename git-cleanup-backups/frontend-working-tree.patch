-         RETURNING *`,
-        [name, address, nowIso(), deviceId, userId]
-      );
-      if (!result.rows[0]) {
-        return null;
-      }
-      return serializeDevice(result.rows[0]);
-    },
-    async unbindDevice({ userId, deviceId }) {
