PORT=3001
FRONTEND_ORIGIN=http://127.0.0.1:4173,http://127.0.0.1:5173,http://localhost:4173,http://localhost:5173
# SECURITY: do not use admin/admin in production.
# Set strong non-default values for both credentials before deployment.
ADMIN_USERNAME=change-this-admin-username
ADMIN_PASSWORD=change-this-admin-password
DATABASE_URL=postgresql://roastek:change-this-postgres-password@127.0.0.1:5432/roastek
DB_POOL_MAX=10
DB_CONNECT_RETRIES=20
DB_CONNECT_RETRY_DELAY_MS=1000
LEGACY_DEVICES_FILE=
