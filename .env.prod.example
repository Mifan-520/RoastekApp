# ============================================
# 生产环境 .env 模板 (正式域名)
# 适用于服务器正式部署
# ============================================

# 前端配置
# 替换为你的正式域名或服务器 IP
VITE_API_BASE_URL=https://your-domain.com/api
WEB_PORT=80
FRONTEND_ORIGIN=https://your-domain.com

# PostgreSQL 配置
# 请务必修改为强密码
POSTGRES_DB=roastek
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<生成一个强密码，例如: Rc8#kL2$mNp9Qw>

# 账户配置
# 请务必修改为强密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<设置一个强管理员密码>
USER_USERNAME=user
USER_PASSWORD=<设置一个强普通用户密码>
